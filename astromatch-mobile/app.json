{
  "expo": {
    "name": "astromatch-mobile",
    "slug": "astromatch-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Autoriser l’enregistrement de messages vocaux dans les conversations."
      },
      "bundleIdentifier": "com.olivierdokkan.astromatchmobile"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.olivierdokkan.astromatchmobile"
    },
    "web": {},
    "plugins": [
      "expo-av",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow astromatch to use your location for nearby context."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow astromatch to choose a profile photo."
        }
      ],
      "expo-notifications"
    ]
  }
}
