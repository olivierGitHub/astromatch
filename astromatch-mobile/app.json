{
  "expo": {
    "name": "astromatch-mobile",
    "slug": "astromatch-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.olivierdokkan.astromatchmobile"
    },
    "web": {},
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow astromatch to use your location for nearby context."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow astromatch to choose a profile photo."
        }
      ],
      "expo-notifications"
    ]
  }
}
