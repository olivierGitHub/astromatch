# Copy to .env and fill for local overrides (never commit .env)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/astromatch
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# ASTROMATCH_JWT_SECRET=<256-bit+ random string for HS256>
# Never set in production: astromatch.recovery.expose-reset-token=true (returns reset token in forgot-password JSON for dev only)
